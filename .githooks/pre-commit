#!/bin/sh
# 보안 검사 Python 스크립트 실행 (Windows / Mac / Linux 공통)
DIR="$(dirname "$0")"

run_python() {
    exec "$1" "$DIR/pre-commit.py"
}

# 1. PATH에 등록된 python 확인
if command -v python >/dev/null 2>&1; then
    run_python python
fi

# 2. Windows Python Launcher (py)
if command -v py >/dev/null 2>&1; then
    exec py -3 "$DIR/pre-commit.py"
fi

# 3. python3 (Mac/Linux)
if command -v python3 >/dev/null 2>&1; then
    run_python python3
fi

# 4. Windows Anaconda / Miniconda 고정 경로
for p in \
    "/c/ProgramData/anaconda3/python.exe" \
    "/c/ProgramData/miniconda3/python.exe" \
    "$USERPROFILE/anaconda3/python.exe" \
    "$USERPROFILE/miniconda3/python.exe" \
    "$LOCALAPPDATA/anaconda3/python.exe" \
    "$LOCALAPPDATA/miniconda3/python.exe"; do
    if [ -x "$p" ]; then
        run_python "$p"
    fi
done

# 5. Mac Homebrew / pyenv 경로
for p in \
    "$HOME/anaconda3/bin/python" \
    "$HOME/miniconda3/bin/python" \
    "/opt/homebrew/bin/python3" \
    "/usr/local/bin/python3"; do
    if [ -x "$p" ]; then
        run_python "$p"
    fi
done

echo ""
echo "[경고] Python을 찾을 수 없어요."
echo "   Python을 설치하면 보안 검사가 자동으로 활성화됩니다."
echo "   Windows: https://www.python.org/downloads/"
echo "   Mac:     brew install python3"
echo ""
exit 1
