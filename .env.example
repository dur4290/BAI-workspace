# ============================================================
# 환경변수 예시 파일 (.env.example)
#
# 이 파일(.env.example)은 GitHub에 올려도 됩니다.
# 실제 값이 없으니까요.
#
# 기본 작업에서는 API 키를 사용하지 않습니다.
# 요약/분석/보고서 작성은 Codex 세션 안에서 처리하고,
# Python 스크립트는 로컬 파일 처리만 담당하게 만드세요.
#
# 외부 API를 쓰는 별도 앱을 만들 때만 Codex에게 먼저
# 비용과 보안 주의사항을 설명해달라고 요청하세요.
# 실제 .env 파일은 절대 GitHub에 올리지 마세요.
# ============================================================

# /goodbai BAI 피드 설정 예시
# 실제 값은 이 파일에 쓰지 말고 사용자 홈의 .bai-feed.env 또는 워크스페이스의 .bai-feed.env에 둡니다.
#
# BAI_FEED_BASE_URL=https://bai.haiinu.com
# BAI_FEED_NAME=홍길동
# BAI_FEED_API_KEY=실제-api-key
# BAI_FEED_USER_AGENT=BAI-Goodbai-Codex/1.0 (+https://bai.haiinu.com)
#
# 비밀번호 로그인은 legacy fallback입니다. 일반 학생 설정은 API key를 사용합니다.
# BAI_FEED_PASSWORD=실제-비밀번호
