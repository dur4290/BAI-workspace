# ============================================================
# 🔐 보안: API 키 / 비밀번호 / 환경설정
# ============================================================
.env
.env.*
!.env.example
.env.local
.env.production
*.key
*.pem
*.p12
*.pfx
*secret*
*credential*
config.yaml
config.yml
secrets.json

# 도구별 로컬 설정 (개인 인증 정보 포함 가능)
.codex/local.*
.codex/*.local.json
.codex/local-python.json
.python-path

# 참고: .codex/config.toml 은 의도적으로 커밋합니다 (MCP 서버 등록만 담는 파일).
# 환경변수 키(API 키 등)는 절대 config.toml 에 직접 적지 마세요.
# 실제 비밀값은 .env 또는 .codex/local.* 에만 두고, 둘 다 위에서 무시됩니다.

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
*.ipynb_checkpoints/

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json

# ============================================================
# VSCode
# ============================================================
.vscode/
!.vscode/extensions.json
*.code-workspace

# ============================================================
# OS 파일
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
# 데이터 파일 (개인정보 포함 가능성 있는 폴더만 제외)
# ============================================================
data/raw/
data/private/

# ============================================================
# 로그 / 임시 파일
# ============================================================
.setup-done
*.log
*.tmp
*.temp
.cache/
